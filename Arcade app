function tickFlappy(){
  fb.tick++;
  const lv=FL_LV.find(l=>l.id===cLevel)||FL_LV[0];
  fb.spd=lv.spd+fb.tick*0.003;
  fb.gs=(fb.gs+fb.spd)%200;

  // ── BACKGROUND ──
  _fbSky(lv);
  if(lv.bgStyle==='mountains') _fbBgMountains(fb.tick,fb.gs,'rgba(40,20,60,0.5)','rgba(25,10,40,0.7)');
  if(lv.bgStyle==='cityDusk')  _fbBgCity(fb.tick,fb.gs,false);
  if(lv.bgStyle==='nightStorm'){_fbBgStars(fb.tick,fb.gs);_fbLightning(fb.tick);_fbBgRain(fb.tick,fb.gs,false);}
  if(lv.bgStyle==='stormClouds'){_fbBgClouds(fb.tick,fb.gs,'rgba(60,65,80,0.22)');_fbBgRain(fb.tick,fb.gs,true);}
  if(lv.bgStyle==='neonCity')  _fbBgNeonCity(fb.tick,fb.gs);
  if(lv.bgStyle==='deepSpace') _fbBgSpace(fb.tick,fb.gs);

  // ambient particles
  if(fb.tick%8===0){
    if(lv.ambient==='leaves') PARTS.emit(LW+10,rnd(FB.GY*0.2,FB.GY*0.8),{n:1,type:'leaves',s0:1,s1:2,vx:-lv.spd*0.5});
    if(lv.ambient==='embers') PARTS.emit(rnd(0,LW),FB.GY,{n:1,type:'ember',s0:0.5,s1:1.5,up:2});
    if(lv.ambient==='sparks') PARTS.emit(rnd(0,LW),rnd(FB.GY*0.5,FB.GY),{n:1,type:'sparks',s0:0.5,s1:2});
    if(lv.ambient==='stars')  PARTS.emit(rnd(0,LW),rnd(0,FB.GY*0.6),{n:1,type:'stars',s0:0,s1:0.5});
  }

  // physics
  fb.vy=Math.min(fb.vy+FB.GRAV,FB.TERM);fb.by+=fb.vy;

  // spawn
  const gap=lv.gap||FB.GAP;
  const GY=FB.GY;
  if(fb.tick===1||fb.tick%92===0){
    const mn=75,mx=GY-gap-75;
    const ty=mn+Math.random()*(mx-mn);
    const mvY=lv.mv?0:undefined;
    fb.pipes.push({x:LW+FB.PW,ty,sc:false,mvDir:1,mvY:lv.mv?ty:null});
  }

  // moving pipes (levels 3-6)
  if(lv.mv){for(const p of fb.pipes){if(p.mvY!==null){p.mvY+=p.mvDir*0.7;if(p.mvY<60||p.mvY>GY-gap-60)p.mvDir*=-1;p.ty=p.mvY;}}}

  // draw ground first (so pipes render over it correctly)
  _fbGround(lv,fb.gs);

  // draw pipes
  for(const p of fb.pipes){
    p.x-=fb.spd;
    if(!p.sc&&p.x+FB.PW<FB.BX){p.sc=true;setScore(score+1);haptic();SFX.score();PARTS.emit(FB.BX,fb.by,{n:8,type:'sparks'});}
    _fbDrawPipe(p,lv,GY);
  }
  fb.pipes=fb.pipes.filter(p=>p.x+FB.PW>-8);

  // ── BIRK (cyber-sparrow) ──
  const ang=Math.min(Math.max(fb.vy*0.048,-0.5),1.1);
  const wingBob=Math.sin(fb.tick*0.35)*2;
  CTX.save();
  CTX.translate(FB.BX,fb.by+wingBob|0);
  CTX.rotate(ang);
  CTX.scale(-1,1);
  glow(lv.pipeGlow,20);
  CTX.font=`${FB.BR*2.6|0}px serif`;
  CTX.textAlign='center';CTX.textBaseline='middle';
  CTX.fillText('🐦',0,0);
  ng();CTX.restore();

  // trailing particles behind BIRK
  if(fb.tick%3===0)PARTS.emit(FB.BX-8,fb.by,{n:2,type:'stars',s0:0.2,s1:0.8,d0:.04,d1:.07});

  PARTS.update();PARTS.draw();

  // collision
  if(fb.by+FB.BR>GY||fb.by-FB.BR<0){gameOver();return;}
  const I=5;
  for(const p of fb.pipes){
    const L=p.x+I,R=p.x+FB.PW-I;
    if(FB.BX+FB.BR*0.72>L&&FB.BX-FB.BR*0.72<R){
      if(fb.by-FB.BR*0.78<p.ty||fb.by+FB.BR*0.78>p.ty+lv.gap){gameOver();return;}
    }
  }
}
function flap(){haptic();SFX.flap();fb.vy=FB.FLAP;PARTS.emit(FB.BX,fb.by,{n:4,type:'dust',s0:1,s1:3,up:1});}

/* ══════════════════════════════════════════════
   ② GEO DASH
