<!DOCTYPE html> 

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#06060e">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icon.svg">
<title>Arcade Vault</title>
<link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@400;600;700;800;900&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
:root{
  --cyan:#00f2ff;--pink:#ff0a6c;--gold:#ffc107;--green:#00e89a;
  --purple:#a855f7;--orange:#ff6b35;--blue:#3b82f6;--bg:#06060e;
  --st:env(safe-area-inset-top,0px);--sb:env(safe-area-inset-bottom,0px);
}
html,body{height:100%;overflow:hidden;background:var(--bg);font-family:"Exo 2",sans-serif;color:#fff;touch-action:none;overscroll-behavior:none;user-select:none;-webkit-user-select:none;}
button{outline:none;font-family:inherit;cursor:pointer;}

.screen{position:fixed;inset:0;z-index:10;overflow-y:auto;overflow-x:hidden;padding-bottom:calc(var(--sb) + 74px);background:var(--bg);}
.hidden{display:none!important;}

/* GRID */
.ag{position:fixed;inset:0;pointer-events:none;z-index:0;background-image:linear-gradient(rgba(0,242,255,.033)1px,transparent 1px),linear-gradient(90deg,rgba(0,242,255,.033)1px,transparent 1px);background-size:36px 36px;animation:ag 18s linear infinite;}
@keyframes ag{to{background-position:36px 36px;}}

/* NAV */
#nav{position:fixed;bottom:0;left:0;right:0;z-index:200;background:rgba(6,6,14,.97);border-top:1px solid rgba(255,255,255,.07);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);display:flex;padding-bottom:env(safe-area-inset-bottom,0px);}
.nb{flex:1;padding:11px 0 9px;border:none;background:transparent;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:3px;color:rgba(255,255,255,.3);transition:color .14s;position:relative;}
.nb .ni{font-size:20px;transition:filter .14s;}
.nb.on .ni{filter:drop-shadow(0 0 8px currentColor);color:#fff;}
.nb .nl{font-family:“Exo 2”,sans-serif;font-weight:700;font-size:8px;letter-spacing:.1em;color:rgba(255,255,255,.26);}
.nb.on .nl{color:var(--cyan);}
.nbdot{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:28px;height:2px;background:var(--cyan);border-radius:2px;box-shadow:0 0 8px var(--cyan);display:none;}
.nb.on .nbdot{display:block;}

/* COIN BADGE */
.cb{display:inline-flex;align-items:center;gap:7px;background:rgba(255,193,7,.11);border:1px solid rgba(255,193,7,.28);border-radius:22px;padding:7px 16px;}
.cb span{font-family:“Exo 2”,sans-serif;font-weight:700;font-size:15px;color:var(--gold);letter-spacing:.04em;}

/* GAME CARDS */
.hub-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.hc{background:linear-gradient(145deg,#0d0d22,#080818);border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:18px 12px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:8px;transition:all .13s;}
.hc:active{transform:scale(.92)!important;}

/* GAME ROWS */
.gr{background:linear-gradient(135deg,rgba(13,13,34,.98),rgba(8,8,22,.98));border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:20px 18px;cursor:pointer;display:flex;align-items:center;gap:16px;transition:all .13s;margin-bottom:12px;}
.gr:active{transform:scale(.97);}

/* LEVEL ROWS */
.lr{background:linear-gradient(135deg,rgba(13,13,34,.97),rgba(8,8,24,.98));border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:16px 18px;cursor:pointer;display:flex;align-items:center;gap:14px;transition:all .12s;margin-bottom:10px;}
.lr:active{transform:scale(.96);}
.lr.locked{opacity:.45;cursor:default;}

/* SHOP */
.stab{flex:1;padding:9px 4px;border-radius:10px;border:none;background:rgba(255,255,255,.04);border-bottom:2px solid transparent;color:rgba(255,255,255,.32);font-family:“Exo 2”,sans-serif;font-weight:700;font-size:8px;letter-spacing:.1em;transition:all .12s;}
.stab.on{background:rgba(255,193,7,.18);border-bottom:2px solid var(--gold);color:var(--gold);}
.shop-grid{display:grid;grid-template-columns:1fr 1fr;gap:11px;}
.shop-grid.wide{grid-template-columns:1fr;}
.sc{background:linear-gradient(145deg,#0e0e22,#090918);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:15px 13px;display:flex;flex-direction:column;gap:10px;position:relative;overflow:hidden;}
.scbtn{flex:1;padding:8px 10px;border-radius:9px;font-family:“Exo 2”,sans-serif;font-weight:700;font-size:10px;letter-spacing:.06em;transition:all .12s;border:1px solid;white-space:nowrap;}

/* STATS */
.sg{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:18px;}
.scard{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:14px 12px;}

/* TOAST */
#toast{position:fixed;top:calc(var(--st) + 58px);left:50%;transform:translateX(-50%) translateY(-16px);z-index:500;padding:11px 20px;border-radius:10px;font-family:“Exo 2”,sans-serif;font-weight:600;font-size:11px;letter-spacing:.06em;opacity:0;transition:opacity .22s,transform .22s;pointer-events:none;white-space:nowrap;}
#toast.on{opacity:1;transform:translateX(-50%) translateY(0);}

/* GAME UI */
#gs{position:fixed;inset:0;z-index:50;display:flex;flex-direction:column;background:#030308;}
#gh{display:flex;align-items:center;gap:10px;padding:calc(var(--st) + 10px) 14px 10px;background:rgba(6,6,14,.97);border-bottom:1px solid rgba(255,255,255,.07);backdrop-filter:blur(14px);flex-shrink:0;z-index:60;}
#ghback{font-family:“Exo 2”,sans-serif;font-weight:600;font-size:9px;padding:8px 12px;border:1px solid rgba(255,255,255,.16);background:rgba(255,255,255,.04);color:#aaa;border-radius:8px;letter-spacing:.06em;}
#ghtitle{font-family:“Exo 2”,sans-serif;font-weight:800;font-size:13px;letter-spacing:.12em;flex:1;white-space:nowrap;overflow:hidden;}
#ghsc{font-family:“Exo 2”,sans-serif;font-weight:700;font-size:11px;white-space:nowrap;}
#ghcoin{font-family:“Exo 2”,sans-serif;font-weight:700;font-size:10px;color:var(--gold);flex-shrink:0;}
#cwrap{flex:1;position:relative;overflow:hidden;background:#030308;}
#gc2{position:absolute;display:block;}

/* OVERLAY */
#govl{position:absolute;inset:0;z-index:20;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;background:rgba(4,4,12,.87);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);padding:32px 24px;}
#govl-title{font-family:“Exo 2”,sans-serif;font-weight:900;font-size:clamp(20px,5.5vw,34px);letter-spacing:.14em;text-align:center;}
#govl-stats{display:flex;gap:24px;}
.gs-stat .sl{font-family:“Rajdhani”,sans-serif;font-size:10px;letter-spacing:.2em;color:rgba(255,255,255,.38);}
.gs-stat .sv{font-family:“Exo 2”,sans-serif;font-weight:800;font-size:26px;color:rgba(255,255,255,.88);}
.gs-stat.gold .sv{color:var(--gold);}
#govl-btn{font-family:“Exo 2”,sans-serif;font-weight:800;font-size:13px;padding:15px 34px;border:2px solid;background:transparent;border-radius:12px;letter-spacing:.18em;transition:all .14s;animation:bp 1.8s ease-in-out infinite;}
@keyframes bp{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}
#govl-hint{font-family:“Rajdhani”,sans-serif;font-size:11px;color:rgba(255,255,255,.28);letter-spacing:.1em;text-align:center;line-height:2;}

/* DPAD */
#dpad{position:absolute;bottom:calc(var(--sb) + 12px);left:0;right:0;display:flex;justify-content:center;gap:10px;z-index:8;pointer-events:none;}
.dpg{display:grid;grid-template-columns:58px 58px 58px;grid-template-rows:58px 58px;gap:6px;pointer-events:all;}
.dpb{width:58px;height:58px;border-radius:12px;font-size:16px;background:rgba(255,255,255,.08);border:1.5px solid rgba(255,255,255,.2);color:rgba(255,255,255,.7);display:flex;align-items:center;justify-content:center;}
.dpb:active{background:rgba(255,255,255,.22);}
.dplr{width:76px;height:62px;border-radius:14px;font-size:22px;background:rgba(255,193,7,.08);border:1.5px solid rgba(255,193,7,.35);color:var(--gold);pointer-events:all;display:flex;align-items:center;justify-content:center;}
.dplr:active{background:rgba(255,193,7,.22);}

/* HIT ANIM (temple lives) */
@keyframes hit{0%{box-shadow:inset 0 0 0 4px rgba(255,10,108,0)}20%{box-shadow:inset 0 0 0 4px rgba(255,10,108,.8)}100%{box-shadow:inset 0 0 0 4px rgba(255,10,108,0)}}
.hitanim{animation:hit .35s ease-out;}

/* SCORE FLASH */
@keyframes sf{0%{transform:scale(1.45)}100%{transform:scale(1)}}
.flash{animation:sf .2s ease-out forwards;}

/* LOGO */
.lp{animation:lp 3.2s ease-in-out infinite;}
@keyframes lp{0%,100%{text-shadow:0 0 6px var(--cyan),0 0 22px var(--cyan),0 0 50px rgba(0,242,255,.3);}50%{text-shadow:0 0 12px var(--cyan),0 0 40px var(--cyan),0 0 80px rgba(0,242,255,.5);}}

/* DAILY */
.daily{background:linear-gradient(135deg,rgba(155,93,229,.14),rgba(0,242,255,.07));border:1px solid rgba(155,93,229,.28);border-radius:14px;padding:16px 18px;display:flex;align-items:center;gap:14px;}

::-webkit-scrollbar{width:0;height:0;}
</style>

</head>
<body>
<div class="ag"></div>
<div id="toast"></div>

<!-- ═══ HUB ═══ -->

<div id="s-hub" class="screen">
 <div style="position:relative;z-index:1;padding:calc(var(--st) + 28px) 20px 0;">
  <div style="text-align:center;margin-bottom:24px;">
   <div style="font-size:48px;margin-bottom:11px;filter:drop-shadow(0 0 18px var(--gold))">🕹️</div>
   <div class="lp" style="font-family:Exo 2,sans-serif;font-weight:900;font-size:clamp(22px,6.5vw,46px);letter-spacing:.18em;color:var(--cyan);">ARCADE VAULT</div>
   <div style="font-family:Rajdhani,sans-serif;font-size:11px;letter-spacing:.35em;color:rgba(255,255,255,.26);margin-top:7px;">5 GAMES · LEVELS · EARN COINS</div>
  </div>
  <div style="display:flex;justify-content:center;margin-bottom:22px;"><div class="cb"><span style="font-size:15px;">🪙</span><span id="hub-coins">0</span></div></div>
  <div style="font-family:Exo 2,sans-serif;font-weight:700;font-size:10px;letter-spacing:.2em;color:rgba(255,255,255,.32);margin-bottom:12px;">QUICK PLAY</div>
  <div class="hub-grid" id="hub-cards"></div>
  <div style="height:16px;"></div>
  <div class="daily">
   <span style="font-size:30px;">🎯</span>
   <div>
    <div style="font-family:Exo 2,sans-serif;font-weight:700;font-size:10px;color:var(--purple);letter-spacing:.1em;">DAILY CHALLENGE</div>
    <div style="font-family:Rajdhani,sans-serif;font-size:12px;color:rgba(255,255,255,.5);margin-top:3px;">Score 15 in Geo Dash – Level 2</div>
    <div style="font-family:Exo 2,sans-serif;font-weight:700;font-size:10px;color:var(--gold);margin-top:5px;">🪙 +120 COIN REWARD</div>
   </div>
  </div>
 </div>
</div>

<!-- ═══ GAMES ═══ -->

<div id="s-games" class="screen hidden">
