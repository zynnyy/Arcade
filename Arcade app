function _fbGround(lv,gs){
  CTX.fillStyle=lv.ground;CTX.fillRect(0,FB.GY,LW,LH-FB.GY);
  CTX.fillStyle=lv.groundTop;CTX.fillRect(0,FB.GY,LW,9);
  glow(lv.pipeGlow,5);CTX.fillStyle=lv.pipeGlow+'66';CTX.fillRect(0,FB.GY,LW,2);ng();
  CTX.fillStyle='rgba(255,255,255,0.05)';
  for(let dx=-gs%66;dx<LW;dx+=66)CTX.fillRect(dx|0,(FB.GY+11)|0,36,2);
