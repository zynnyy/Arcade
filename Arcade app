}
function _fbBgNeonCity(tick,gs){
  for(let L=0;L<3;L++){
    const spd=[0.05,0.15,0.3][L],cnt=[18,12,7][L],baseY=FB.GY*[0.75,0.65,0.5][L];
    for(let i=0;i<cnt+2;i++){
      const bx=((i*(LW/cnt+10))-(gs*spd))%(LW+120)-60;
      const bh=40+(i*53)%(L===2?180:100);const bw=22+(i*11)%40;
      CTX.fillStyle='#020004';CTX.fillRect(bx|0,(baseY-bh)|0,bw,bh+5);
      // neon trim
      const nc=pick(['#00f2ff','#ff0a6c','#a855f7','#ffc107']);
      if(L===2){glow(nc,10);CTX.fillStyle=nc;CTX.fillRect(bx|0,(baseY-bh-2)|0,bw,2);ng();}
      // windows
      CTX.fillStyle=`rgba(${L===0?'255,200,50':'100,200,255'},${0.1+Math.sin(tick*0.03+i)*0.08})`;
      for(let wy=6;wy<bh-6;wy+=10)for(let wx=3;wx<bw-3;wx+=8){if(Math.sin(i*13+wy+wx)>0.2)CTX.fillRect((bx+wx)|0,(baseY-bh+wy)|0,3,5);}
    }
  }
  // neon grid floor
  CTX.save();CTX.globalAlpha=0.25;CTX.strokeStyle='#00f2ff';CTX.lineWidth=0.5;
  for(let x=(-(gs*0.5)%44);x<LW;x+=44){CTX.beginPath();CTX.moveTo(x,FB.GY-20);CTX.lineTo(x,FB.GY);CTX.stroke();}
