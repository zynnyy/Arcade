    [{x:80,y:120,rx:110,ry:55,c:'#7730cc'},{x:270,y:80,rx:90,ry:45,c:'#3b82f6'},{x:330,y:180,rx:70,ry:50,c:'#a855f7'}].forEach(b=>{
