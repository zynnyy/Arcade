  }
  if(lv.bgStyle==='desert'){
    CTX.fillStyle='rgba(30,8,0,0.7)';
    for(let i=0;i<5;i++){const mx=((i*140+30)-(boff*0.04))%LW,mh=40+(i*37)%70;CTX.fillRect((mx-5)|0,(GD.FL-mh-60)|0,80+(i*19)%50,mh+60);}
    CTX.save();CTX.globalAlpha=0.05;CTX.strokeStyle='#ff8844';CTX.lineWidth=1;
    for(let i=0;i<6;i++){const hy=GD.FL-60+(i*16),wb=Math.sin(t*0.08+i)*4;CTX.beginPath();CTX.moveTo(0,hy+wb);CTX.lineTo(LW,hy+wb*0.5);CTX.stroke();}
    CTX.restore();
    if(t%5===0)PARTS.emit(rnd(0,LW),GD.FL-rnd(0,30),{n:1,type:'dust',s0:0.3,s1:1,d0:.01,d1:.02});
  }
  if(lv.bgStyle==='factory'){
    CTX.save();CTX.globalAlpha=0.07;CTX.strokeStyle=lv.obsGlow;CTX.lineWidth=1.5;
    [{x:70,y:180,r:55,spd:.002},{x:270,y:140,r:40,spd:-.003},{x:180,y:270,r:30,spd:.004}].forEach(g=>{
      CTX.save();CTX.translate(g.x,g.y);CTX.rotate(t*g.spd);
      CTX.beginPath();const teeth=10;
      for(let i=0;i<teeth*2;i++){const a=(i/(teeth*2))*Math.PI*2,r=i%2===0?g.r:g.r*0.72;i===0?CTX.moveTo(Math.cos(a)*r,Math.sin(a)*r):CTX.lineTo(Math.cos(a)*r,Math.sin(a)*r);}
      CTX.closePath();CTX.stroke();CTX.restore();
    });
    CTX.restore();
    if(t%4===0)PARTS.emit(rnd(0,LW),GD.FL-rnd(0,20),{n:1,type:'sparks',s0:1,s1:3,up:2,d0:.04,d1:.08});
  }
  if(lv.bgStyle==='vortex'){
    CTX.save();CTX.globalAlpha=0.045;CTX.strokeStyle=lv.obsGlow;
    for(let r=20;r<280;r+=28){const wb=Math.sin(t*0.015+r*0.04)*6;CTX.lineWidth=0.5;CTX.beginPath();CTX.arc(LW/2,GD.FL/2,r+wb,0,Math.PI*2);CTX.stroke();}
    CTX.restore();
    if(t%3===0)PARTS.emit(rnd(0,LW),rnd(0,GD.FL),{n:1,type:'electric',s0:0.5,s1:2,d0:.05,d1:.09});
  }
  if(lv.bgStyle==='dark'){
    if(t%4===0)PARTS.emit(rnd(0,LW),rnd(0,GD.FL),{n:1,type:'blood',s0:0.3,s1:1.5,d0:.015,d1:.03});
  }
  if(lv.bgStyle==='warp'){
    const pulse=0.5+Math.sin(t*0.15)*0.4;
    CTX.save();CTX.globalAlpha=pulse*0.12;CTX.fillStyle=lv.obsGlow;CTX.fillRect(0,0,LW,LH);CTX.restore();
    CTX.save();CTX.globalAlpha=0.18;CTX.strokeStyle=lv.obsGlow;CTX.lineWidth=0.8;
    for(let i=0;i<20;i++){const lx=((i*(LW/8))-(boff*3.5))%(LW*1.2)-20;CTX.beginPath();CTX.moveTo(lx,0);CTX.lineTo(lx,LH);CTX.stroke();}
    CTX.restore();
    if(t%2===0)PARTS.emit(rnd(0,LW),rnd(0,GD.FL),{n:1,type:'stars',s0:0.5,s1:2,d0:.06,d1:.1});
  }
  // BPM pulse
  const bpm=lv.bpm||130,beatF=Math.round(60/(bpm/60)/60*60);
  if(t%beatF<3){CTX.save();CTX.globalAlpha=0.04;CTX.fillStyle=lv.obsGlow;CTX.fillRect(0,0,LW,LH);CTX.restore();}
  // speed lines
  CTX.save();CTX.globalAlpha=0.08;CTX.strokeStyle=lv.obsGlow;CTX.lineWidth=1;
  for(let i=0;i<12;i++){const lx=((i*(LW/8))-boff*1.4)%(LW*1.4)-30;CTX.beginPath();CTX.moveTo(lx,0);CTX.lineTo(lx+LH*0.48,LH);CTX.stroke();}
  CTX.restore();
}

function tickGeo(){
  gd.tick++; gd.spd=GD.SPD0+gd.tick*0.0045; gd.boff=(gd.boff+gd.spd)%200;
  gd.segTimer++;
  if(gd.segTimer>220){gd.segTimer=0;gd.seg=(gd.seg+1)%5;}
  const FL=GD.FL;
  const lv=GEO_LV.find(l=>l.id===cLevel)||GEO_LV[0];

  // ── BACKGROUND ──
  _gdBg(lv,gd.boff);

  // ceiling for lv7 or seg1
  const hasCeil=lv.ceiling||(gd.seg===1&&cLevel<7);
  if(hasCeil){
    gd.ceilActive=true;if(!gd.ceilY)gd.ceilY=80;
    glow(lv.obsGlow,8);CTX.fillStyle=lv.fl;CTX.fillRect(0,0,LW,gd.ceilY);
    CTX.fillStyle=lv.obsGlow;CTX.fillRect(0,gd.ceilY-2,LW,2);ng();
  } else if(!lv.ceiling){gd.ceilActive=false;gd.ceilY=0;}

  // dark-zone overlay (seg2)
  if(gd.seg===2&&cLevel<6){CTX.save();CTX.globalAlpha=0.45;CTX.fillStyle='#000';CTX.fillRect(0,0,LW,LH);CTX.restore();}

  // ── FLOOR ──
  CTX.fillStyle=lv.fl;CTX.fillRect(0,FL,LW,LH-FL);
  CTX.strokeStyle=lv.obsGlow+'22';CTX.lineWidth=1;
  const tw=44;for(let tx=-(gd.boff%tw);tx<LW;tx+=tw){CTX.beginPath();CTX.moveTo(tx|0,FL);CTX.lineTo(tx|0,LH);CTX.stroke();}
  glow(lv.obsGlow,14);CTX.fillStyle=lv.obsGlow;CTX.fillRect(0,FL,LW,2);ng();

  // ── ORB RINGS (levels with orbRings) ──
  if(lv.orbRings&&gd.tick%180===90&&gd.jumps>0){
    if(!gd.orbs)gd.orbs=[];
    gd.orbs.push({x:LW+20,y:FL-rnd(80,220),r:18,active:true});
  }
  if(gd.orbs){
    gd.orbs.forEach(o=>{
      o.x-=gd.spd;
      if(!o.active)return;
      const pulse=0.7+Math.sin(gd.tick*0.15)*0.3;
      glow('#ffc107',12*pulse);CTX.strokeStyle='#ffc107';CTX.lineWidth=2.5;
      CTX.beginPath();CTX.arc(o.x|0,o.y|0,o.r,0,Math.PI*2);CTX.stroke();ng();
      // collect
      if(Math.abs(GD.PX-o.x)<o.r+8&&Math.abs(gd.py-GD.CH/2-o.y)<o.r+8){
        o.active=false;gd.vy=GD.JV;gd.jumps=Math.max(gd.jumps-1,0);
        PARTS.emit(o.x,o.y,{n:10,type:'sparks'});SFX.jump();
      }
    });
    gd.orbs=gd.orbs.filter(o=>o.x>-30);
  }

  // ── PHYSICS ──
  gd.vy=Math.min(gd.vy+GD.GV,GD.TERM);gd.py+=gd.vy;
  const prevOnGnd=gd.onGnd;
  gd.onGnd=gd.py>=FL;
  if(gd.onGnd){
    gd.py=FL;gd.vy=0;gd.jumps=0;
    if(gd.sqY<1){gd.sqX=1.3;gd.sqY=0.65;}
    if(!prevOnGnd){SFX.land();PARTS.emit(GD.PX,FL,{n:5,type:'dust',s0:1,s1:3,up:0.5});}
  }
  gd.sqX+=(1-gd.sqX)*0.18;gd.sqY+=(1-gd.sqY)*0.18;
  if(hasCeil&&gd.py-GD.CH<gd.ceilY){gameOver();return;}
  gd.rot+=gd.onGnd?0.085:0.15;

  // ── CUBE TRAIL ──
  if(!gd.trail)gd.trail=[];
  gd.trail.unshift({x:GD.PX+GD.CW/2,y:gd.py-GD.CH/2,sqX:gd.sqX,sqY:gd.sqY});
  if(gd.trail.length>8)gd.trail.pop();
  for(let i=1;i<gd.trail.length;i++){
    const tp=gd.trail[i],ta=1-i/gd.trail.length,tcw=GD.CW*tp.sqX*0.9,tch=GD.CH*tp.sqY*0.9;
    CTX.globalAlpha=ta*0.3;CTX.fillStyle=lv.obsCol;
    rr(tp.x-tcw/2,tp.y-tch/2,tcw,tch,2);CTX.fill();
  }
  CTX.globalAlpha=1;

  // ── OBSTACLES ──
  const interval=Math.max(48,95-gd.tick*0.05);
  if(gd.tick%Math.round(interval)===0){
    let types=['spike','spike','dspike','block','tall','platform'];
    if(gd.seg===1)types=['spike','spike','block'];
    if(gd.seg===2)types=['dspike','tall','platform'];
    if(gd.seg===3)types=['spike','dspike','dspike','tall'];
    if(gd.seg===4)types=['block','platform','tall'];
    gdSpawn(types[Math.floor(Math.random()*types.length)]);
  }
  for(const o of gd.obs){
    o.x-=gd.spd;o.phase+=0.07;
    const bx=o.x|0;
    glow(lv.obsGlow,10);CTX.fillStyle=lv.obsCol;
    if(o.type==='spike'){
      CTX.beginPath();CTX.moveTo(bx,FL);CTX.lineTo(bx+17,FL-35);CTX.lineTo(bx+34,FL);CTX.closePath();CTX.fill();
      CTX.fillStyle=lv.obsGlow+'55';CTX.beginPath();CTX.moveTo(bx+3,FL);CTX.lineTo(bx+17,FL-32);CTX.lineTo(bx+20,FL-25);CTX.closePath();CTX.fill();
      o.hx1=bx+4;o.hx2=bx+30;o.hy=FL-27;
    }else if(o.type==='dspike'){
      for(let s=0;s<2;s++){const sx=bx+s*22;CTX.fillStyle=lv.obsCol;CTX.beginPath();CTX.moveTo(sx,FL);CTX.lineTo(sx+11,FL-28);CTX.lineTo(sx+22,FL);CTX.closePath();CTX.fill();}
      o.hx1=bx+3;o.hx2=bx+41;o.hy=FL-22;
    }else if(o.type==='block'){
      rr(bx,FL-30,30,30,4);CTX.fill();
      CTX.strokeStyle=lv.obsGlow+'88';CTX.lineWidth=1.5;rr(bx+1,FL-29,28,28,3);CTX.stroke();
      CTX.fillStyle='rgba(255,255,255,0.1)';CTX.fillRect(bx+4,FL-26,8,8);
      o.hx1=bx+3;o.hx2=bx+27;o.hy=FL-27;
    }else if(o.type==='tall'){
      rr(bx,FL-60,30,60,4);CTX.fill();
      CTX.strokeStyle=lv.obsGlow+'66';CTX.lineWidth=1.5;rr(bx+1,FL-59,28,58,3);CTX.stroke();
      CTX.fillStyle='rgba(255,255,255,0.08)';CTX.fillRect(bx+4,FL-56,8,8);CTX.fillRect(bx+4,FL-30,8,8);
      o.hx1=bx+3;o.hx2=bx+27;o.hy=FL-57;
    }else if(o.type==='platform'){
      const py2=FL-95;CTX.fillStyle=lv.obsCol;rr(bx,py2,50,18,4);CTX.fill();
      glow(lv.obsGlow,16);CTX.fillStyle=lv.obsGlow;CTX.fillRect(bx,py2,50,2);ng();
      o.hx1=bx+2;o.hx2=bx+48;o.hy=py2;o.hyBot=py2+18;o.isPlatform=true;
    }
    ng();
    if(!o.passed&&o.x+60<GD.PX){o.passed=true;setScore(score+1);haptic();SFX.score();PARTS.emit(GD.PX,gd.py-GD.CH/2,{n:6,type:'sparks',colors:[lv.obsGlow]});}
  }
  gd.obs=gd.obs.filter(o=>o.x+70>0);

  // ── DRAW BLOC (cube hero, uses equipped skin) ──
  const skin=SHOP_D.find(s=>s.id===(store.equipped?.skin||'skin_default'));
  const sc0=skin?.c0||lv.obsGlow,sc1=skin?.c1||lv.obsCol,sGlow=skin?.glow||lv.obsGlow;
  const cw=GD.CW*gd.sqX,ch=GD.CH*gd.sqY;
  const cx=GD.PX+GD.CW/2,cy=gd.py-GD.CH/2;
  CTX.save();CTX.translate(cx|0,cy|0);CTX.rotate(gd.rot);
  const sideD=5;
  CTX.fillStyle=sc1+'aa';
  CTX.beginPath();CTX.moveTo(cw/2,-ch/2);CTX.lineTo(cw/2+sideD,-ch/2+sideD);CTX.lineTo(cw/2+sideD,ch/2+sideD);CTX.lineTo(cw/2,ch/2);CTX.closePath();CTX.fill();
  CTX.fillStyle=sc0+'99';
  CTX.beginPath();CTX.moveTo(-cw/2,-ch/2);CTX.lineTo(cw/2,-ch/2);CTX.lineTo(cw/2+sideD,-ch/2+sideD);CTX.lineTo(-cw/2+sideD,-ch/2+sideD);CTX.closePath();CTX.fill();
  glow(sGlow,22);
  const fg=CTX.createLinearGradient(-cw/2,-ch/2,cw/2,ch/2);
  fg.addColorStop(0,sc0);fg.addColorStop(1,sc1);
  CTX.fillStyle=fg;rr(-cw/2,-ch/2,cw,ch,3);CTX.fill();
  CTX.strokeStyle=sGlow+'66';CTX.lineWidth=1.5;rr(-cw/2+1,-ch/2+1,cw-2,ch-2,2);CTX.stroke();
  CTX.fillStyle='rgba(255,255,255,0.38)';
  CTX.beginPath();CTX.arc(0,0,2.5,0,Math.PI*2);CTX.fill();
  for(const[dx,dy]of[[-cw*.28,-ch*.26],[cw*.28,-ch*.26],[-cw*.28,ch*.26],[cw*.28,ch*.26]]){CTX.beginPath();CTX.arc(dx,dy,2.5,0,Math.PI*2);CTX.fill();}
  ng();CTX.restore();

  PARTS.update();PARTS.draw();

  // ── COLLISION ──
  const pl=GD.PX+4,pr=GD.PX+GD.CW-4,pt=gd.py-GD.CH+4,pb=gd.py-4;
  for(const o of gd.obs){
    if(o.isPlatform){if(pr>o.hx1&&pl<o.hx2&&pb>=o.hy&&pt<o.hy){gameOver();return;}}
    else{if(!o.hx1)continue;if(pr>o.hx1&&pl<o.hx2&&pb>o.hy){gameOver();return;}}
  }
  if(hasCeil&&gd.py-GD.CH<(gd.ceilY||0)+2){gameOver();return;}
}
function geoJump(){
  if(gd.jumps<2){haptic();SFX.jump();gd.vy=GD.JV;gd.jumps++;gd.sqX=0.7;gd.sqY=1.35;
    PARTS.emit(GD.PX,gd.py,{n:6,type:'dust',s0:1,s1:3,up:1});
  }
}

/* ══════════════════════════════════════════════
   ③ TEMPLE ESCAPE
   Character: 🏂 snowboarder
   COLLISION FIXED: uses a 2-frame grace window +
   per-obstacle lane-hit confirmed by exact laneMatch.
   Snowboarder leans into turns.
   Snow/winter aesthetic. Lives system: 3 hits before game over.
══════════════════════════════════════════════ */
const TR_VY=215,TR_PLY=582,TR_LC=[78,195,312],TR_VC=195;
let tr={};
function resetTemple(){
  tr={
    lane:1,tgtX:TR_LC[1],lerpX:TR_LC[1],cool:0,
    lean:0,
    obs:[],coins:[],
    tick:0,spd:1.7,flo:0,
    lives:3,hitCool:0,
    particles:[],
  };
}
function templeShift(d){
  if(tr.cool>0)return;
  const nl=Math.max(0,Math.min(2,tr.lane+d));
  if(nl===tr.lane)return;
  tr.lean=d*0.4; tr.lane=nl; tr.tgtX=TR_LC[nl]; tr.cool=18; haptic();
}
function trPX(lane,d){return TR_VC+(TR_LC[lane]-TR_VC)*d;}
function trPY(d){return TR_VY+(TR_PLY-TR_VY)*d;}

function _trBg(biome,tick){
  const bg=CTX.createLinearGradient(0,0,0,LH);
  const s=biome.bgStyle;
  if(s==='aurora'){
    bg.addColorStop(0,'#04080f');bg.addColorStop(.6,'#0a1828');bg.addColorStop(1,'#081422');
    CTX.fillStyle=bg;CTX.fillRect(0,0,LW,LH);
    // aurora bands
    const aColors=['rgba(0,242,255,0.18)','rgba(0,232,154,0.14)','rgba(100,180,255,0.12)'];
    for(let i=0;i<3;i++){
      const ay=60+i*55+Math.sin(tick*0.015+i*2.1)*28,amp=20+i*7;
      const ag=CTX.createLinearGradient(0,ay-amp,0,ay+amp);
      ag.addColorStop(0,'transparent');ag.addColorStop(0.5,aColors[i]);ag.addColorStop(1,'transparent');
      CTX.fillStyle=ag;CTX.beginPath();CTX.ellipse(LW/2,ay+Math.sin(tick*0.02+i)*12,LW*0.75,amp+12,0,0,Math.PI*2);CTX.fill();
    }
    // stars
    for(let i=0;i<40;i++){const sx=(i*137)%LW,sy=(i*91)%140;CTX.globalAlpha=0.3+0.5*Math.sin(tick*0.04+i);CTX.fillStyle='#fff';CTX.fillRect(sx,sy,1.5,1.5);}
    CTX.globalAlpha=1;
    // mountain silhouettes
    CTX.fillStyle='rgba(10,20,40,0.7)';
    for(let i=0;i<6;i++){const mx=(i*65+20)%LW,mh=50+i*20;CTX.beginPath();CTX.moveTo(mx,TR_VY);CTX.lineTo(mx+mh*0.55,TR_VY-mh);CTX.lineTo(mx+mh*1.1,TR_VY);CTX.closePath();CTX.fill();}
  } else if(s==='jungle'){
    bg.addColorStop(0,'#020a00');bg.addColorStop(.5,'#061400');bg.addColorStop(1,'#041000');
    CTX.fillStyle=bg;CTX.fillRect(0,0,LW,LH);
    // diagonal light rays
    CTX.save();CTX.globalAlpha=0.07;CTX.fillStyle='#aaff88';
    for(let i=0;i<5;i++){CTX.save();CTX.translate(LW*0.25+i*45,0);CTX.rotate(-0.35+i*0.18);CTX.fillRect(-4,0,8,LH);CTX.restore();}
    CTX.restore();
    // canopy blobs far
    CTX.fillStyle='rgba(0,50,0,0.55)';
    for(let i=0;i<8;i++){const bx=(i*55+(tick*0.12|0))%LW,br=28+i*9;CTX.beginPath();CTX.arc(bx,18+Math.sin(i*1.4)*14,br,0,Math.PI*2);CTX.fill();}
    // canopy blobs near
    CTX.fillStyle='rgba(0,80,0,0.38)';
    for(let i=0;i<10;i++){const bx=(i*42+8+(tick*0.06|0))%(LW+20)-10,br=18+i*5;CTX.beginPath();CTX.arc(bx,38+Math.sin(i*2.1)*10,br,0,Math.PI*2);CTX.fill();}
  } else if(s==='lava'){
    bg.addColorStop(0,'#0f0100');bg.addColorStop(.5,'#220400');bg.addColorStop(1,'#1a0200');
    CTX.fillStyle=bg;CTX.fillRect(0,0,LW,LH);
    // volcano silhouette
    CTX.fillStyle='#080000';
    CTX.beginPath();CTX.moveTo(0,TR_VY);CTX.lineTo(LW*0.5,TR_VY);CTX.lineTo(LW*0.5-55,TR_VY-110);CTX.lineTo(LW*0.5+55,TR_VY-110);CTX.lineTo(LW,TR_VY);CTX.closePath();CTX.fill();
    // vent glow
    const lg=CTX.createRadialGradient(LW*0.5,TR_VY-110,0,LW*0.5,TR_VY-110,90);
    lg.addColorStop(0,`rgba(255,120,0,${0.28+0.14*Math.sin(tick*0.05)})`);lg.addColorStop(1,'transparent');
    CTX.fillStyle=lg;CTX.fillRect(LW*0.25,TR_VY-200,LW*0.5,200);
    // lava crack lines
    CTX.strokeStyle=`rgba(255,90,0,${0.22+0.1*Math.sin(tick*0.07)})`;CTX.lineWidth=1.5;
    for(let i=0;i<5;i++){const cl=(i*67+20)%LW,cy=TR_VY-(i*15+18);CTX.beginPath();CTX.moveTo(cl,TR_VY);CTX.lineTo(cl+Math.sin(i*1.7)*22,cy);CTX.stroke();}
  } else if(s==='cave'){
    bg.addColorStop(0,'#050010');bg.addColorStop(.6,'#0a0020');bg.addColorStop(1,'#070015');
    CTX.fillStyle=bg;CTX.fillRect(0,0,LW,LH);
    // bioluminescent blobs
    const bcols=['rgba(168,85,247,0.22)','rgba(90,0,200,0.15)','rgba(0,200,255,0.12)'];
    for(let i=0;i<6;i++){
      const bx=i*68+30,by=50+i*18,br=22+i*10,ba=0.55+0.4*Math.sin(tick*0.03+i*1.2);
      const gr=CTX.createRadialGradient(bx,by,0,bx,by,br);
      gr.addColorStop(0,bcols[i%3]);gr.addColorStop(1,'transparent');
      CTX.globalAlpha=ba;CTX.fillStyle=gr;CTX.fillRect(bx-br,by-br,br*2,br*2);
    }
    CTX.globalAlpha=1;
    // crystal stalactites
    CTX.fillStyle='rgba(120,60,200,0.4)';
    for(let i=0;i<8;i++){const sx=i*50+15,sh=28+i*12;CTX.beginPath();CTX.moveTo(sx-8,0);CTX.lineTo(sx+8,0);CTX.lineTo(sx,sh);CTX.closePath();CTX.fill();}
  } else if(s==='sky'){
    bg.addColorStop(0,'#0a1e3d');bg.addColorStop(.5,'#1a3a70');bg.addColorStop(1,'#0e2850');
    CTX.fillStyle=bg;CTX.fillRect(0,0,LW,LH);
    // cloud layers
    const co=[(tick*0.35)%LW,(tick*0.2)%LW,(tick*0.55)%LW];
    for(let c=0;c<3;c++){
      const cx=co[c]|0,cy=40+c*30;
      CTX.fillStyle='rgba(200,220,255,0.18)';
      for(let j=0;j<3;j++){const jx=cx+j*44-LW*(cx>LW-100?1:0);CTX.beginPath();CTX.ellipse(jx,cy,34,16,0,0,Math.PI*2);CTX.fill();}
    }
    // lightning flash
    if(tick%180>175){CTX.fillStyle='rgba(180,220,255,0.18)';CTX.fillRect(0,0,LW,LH);}
  }
}

function tickTemple(){
  tr.tick++;tr.spd=1.7+tr.tick*0.0013;
  if(tr.cool>0)tr.cool--;
  if(tr.hitCool>0)tr.hitCool--;
  tr.flo=(tr.flo+tr.spd*0.022)%1;
  tr.lean*=0.88;

  const biome=BIOMES.find(b=>b.id===cLevel)||BIOMES[0];

  // ── BACKGROUND ──
  _trBg(biome,tr.tick);

  // ambient particles
  if(tr.tick%4===0){
    if(biome.ambient==='snow')PARTS.emit(Math.random()*LW,0,{n:1,type:'snow',s0:0.5,s1:1.5,up:-0.4});
    else if(biome.ambient==='leaves')PARTS.emit(Math.random()*LW,0,{n:1,type:'leaves',s0:0.5,s1:1.2,up:-0.3});
    else if(biome.ambient==='fire')PARTS.emit(rnd(0,LW),TR_VY+5,{n:2,type:'fire',s0:0.5,s1:2,up:1.4});
    else if(biome.ambient==='crystal')PARTS.emit(rnd(0,LW),rnd(0,TR_VY),{n:1,type:'crystal',s0:0.4,s1:1.2});
  }

  // ── TRACK ──
  CTX.fillStyle=biome.track;CTX.fillRect(0,TR_VY,LW,LH-TR_VY);
  const hw0=11,hw1=68;
  for(let l=0;l<3;l++){
    const vx=TR_VC,bx=TR_LC[l];
    CTX.fillStyle=biome.track+'cc';
    CTX.beginPath();CTX.moveTo(vx-hw0,TR_VY);CTX.lineTo(vx+hw0,TR_VY);CTX.lineTo(bx+hw1,LH);CTX.lineTo(bx-hw1,LH);CTX.closePath();CTX.fill();
  }
  // edge rails
  CTX.strokeStyle=biome.rail+'66';CTX.lineWidth=2;
  CTX.beginPath();CTX.moveTo(TR_VC-hw0,TR_VY);CTX.lineTo(TR_LC[0]-hw1,LH);CTX.stroke();
  CTX.beginPath();CTX.moveTo(TR_VC+hw0,TR_VY);CTX.lineTo(TR_LC[2]+hw1,LH);CTX.stroke();
  CTX.strokeStyle=biome.rail+'22';CTX.lineWidth=1;
  CTX.beginPath();CTX.moveTo(TR_VC,TR_VY);CTX.lineTo((TR_LC[0]+TR_LC[1])/2,LH);CTX.stroke();
  CTX.beginPath();CTX.moveTo(TR_VC,TR_VY);CTX.lineTo((TR_LC[1]+TR_LC[2])/2,LH);CTX.stroke();
  // depth lines
  for(let r=0;r<14;r++){
    const t=((r/14)+tr.flo)%1;
    const fy=TR_VY+(LH-TR_VY)*t;
    const fw=(TR_LC[2]+hw1-(TR_LC[0]-hw1))*t;
    const fx=TR_VC-fw/2;
    const da=Math.round(t*0.18*255).toString(16).padStart(2,'0');
    CTX.strokeStyle=biome.rail+da;CTX.lineWidth=1;
    CTX.beginPath();CTX.moveTo(fx|0,fy|0);CTX.lineTo((fx+fw)|0,fy|0);CTX.stroke();
  }
  // VP fade
  const vpg=CTX.createLinearGradient(0,TR_VY-28,0,TR_VY+38);
  vpg.addColorStop(0,biome.bg0+'ff');vpg.addColorStop(1,biome.bg0+'00');
  CTX.fillStyle=vpg;CTX.fillRect(0,TR_VY-28,LW,66);

  // ── COINS ──
  if(tr.tick%30===0)tr.coins.push({lane:Math.floor(Math.random()*3),d:0.06,done:false});
  CTX.textAlign='center';CTX.textBaseline='middle';
  for(const c of tr.coins){
    c.d+=tr.spd*0.016;if(c.d>1.06)continue;
    const cx=trPX(c.lane,c.d),cy=trPY(c.d),cs=Math.max(8,c.d*22);
    glow(biome.rail,8);CTX.font=`${cs|0}px serif`;CTX.fillText(biome.coin||'⭐',cx|0,cy|0);ng();
    if(!c.done&&c.d>0.87&&c.lane===tr.lane){
      c.done=true;setScore(score+1);haptic();SFX.coin();
      PARTS.emit(cx,cy,{n:8,type:'sparks',colors:[biome.rail],s0:2,s1:5});
    }
  }
  tr.coins=tr.coins.filter(c=>c.d<=1.06);

  // ── OBSTACLES ──
  const sp=Math.max(52,96-tr.tick*0.036);
  if(tr.tick%Math.round(sp)===0){
    const blocked=Math.floor(Math.random()*3);
    tr.obs.push({lane:blocked,d:0.06,hit:false,type:Math.floor(Math.random()*biome.obs.length)});
  }
  for(const o of tr.obs){
    o.d+=tr.spd*0.016;if(o.d>1.06)continue;
    const ox=trPX(o.lane,o.d),oy=trPY(o.d),os=Math.max(10,o.d*50);
    glow(biome.rail,12);CTX.font=`${os|0}px serif`;CTX.textBaseline='bottom';CTX.textAlign='center';
    CTX.fillText(biome.obs[o.type],ox|0,oy|0);ng();
    if(!o.hit&&o.d>0.88&&o.d<1.0&&o.lane===tr.lane&&tr.hitCool===0){
      o.hit=true;tr.lives--;tr.hitCool=90;haptic('h');SFX.hit();shake(8);
      PARTS.emit(tr.lerpX,TR_PLY,{n:12,type:'sparks',s0:2,s1:6,colors:[biome.rail]});
      document.getElementById('cwrap').classList.remove('hitanim');
      void document.getElementById('cwrap').offsetWidth;
      document.getElementById('cwrap').classList.add('hitanim');
      if(tr.lives<=0){gameOver();return;}
    }
    if(o.d>=1.0)o.hit=true;
  }
  tr.obs=tr.obs.filter(o=>o.d<=1.06);

  // ── LERP PLAYER ──
  tr.lerpX+=(tr.tgtX-tr.lerpX)*0.22;

  // ── DRAW ZEPHYR ──
  const px=tr.lerpX|0,py=TR_PLY;
  const bob=Math.sin(tr.tick*0.28)*2.5;
  CTX.save();CTX.translate(px,py+bob);CTX.rotate(tr.lean);
  if(tr.hitCool>0&&tr.hitCool%10<5){CTX.globalAlpha=0.4;}
  glow(biome.rail,16);
  CTX.font='42px serif';CTX.textAlign='center';CTX.textBaseline='bottom';
  CTX.fillText('🏂',0,0);
  ng();CTX.restore();

  PARTS.update();PARTS.draw();

  // ── LIVES HUD ──
  CTX.font='14px serif';CTX.textAlign='left';CTX.textBaseline='top';
  for(let i=0;i<3;i++){
    CTX.globalAlpha=i<tr.lives?1:0.2;
    CTX.fillText('❤️',12+i*22,LH-26);
  }
  CTX.globalAlpha=1;

  // ── LANE DOTS ──
  for(let l=0;l<3;l++){
    const a=l===tr.lane;
    CTX.beginPath();CTX.arc(TR_LC[l]|0,(LH-14)|0,a?6.5:3,0,Math.PI*2);
    CTX.fillStyle=a?biome.rail:'rgba(255,255,255,0.22)';CTX.fill();
  }
}

/* ══════════════════════════════════════════════
   ④ NEON SNAKE  (unchanged – already solid)
══════════════════════════════════════════════ */
const SNC=22;
let sn={};
function resetSnake(){
  const cols=Math.floor(LW/SNC),rows=Math.floor(LH/SNC);
  const sx=Math.floor(cols/2),sy=Math.floor(rows/2);
  sn={body:[{x:sx,y:sy},{x:sx-1,y:sy},{x:sx-2,y:sy}],dir:{x:1,y:0},next:{x:1,y:0},food:null,pulses:[],cols,rows,tick:0};
  snFood();
}
function snFood(){
  const{cols,rows,body}=sn;let p;
  do{p={x:Math.floor(Math.random()*cols),y:Math.floor(Math.random()*rows)};}
  while(body.some(b=>b.x===p.x&&b.y===p.y));
  sn.food=p;
}
function snDir(d){
  if(d[0]!==0&&sn.dir.x!==0)return;
  if(d[1]!==0&&sn.dir.y!==0)return;
  sn.next={x:d[0],y:d[1]};
}
function tickSnake(){
  const C=SNC;sn.tick++;
  const fps=Math.max(3,9-Math.floor(score/5));
  CTX.fillStyle='#03050c';CTX.fillRect(0,0,LW,LH);
  // grid
  CTX.strokeStyle='rgba(0,232,154,0.045)';CTX.lineWidth=.5;
  for(let x=0;x<=LW;x+=C){CTX.beginPath();CTX.moveTo(x,0);CTX.lineTo(x,LH);CTX.stroke();}
  for(let y=0;y<=LH;y+=C){CTX.beginPath();CTX.moveTo(0,y);CTX.lineTo(LW,y);CTX.stroke();}

  if(sn.tick%fps===0){
    sn.dir={...sn.next};
    const h={x:sn.body[0].x+sn.dir.x,y:sn.body[0].y+sn.dir.y};
    if(h.x<0||h.x>=sn.cols||h.y<0||h.y>=sn.rows){gameOver();return;}
    if(sn.body.slice(2).some(b=>b.x===h.x&&b.y===h.y)){gameOver();return;}
    sn.body.unshift(h);
    if(h.x===sn.food.x&&h.y===sn.food.y){setScore(score+1);haptic();snFood();sn.pulses.push({x:h.x,y:h.y,a:1});}
    else sn.body.pop();
  }

  for(const p of sn.pulses){
    const r=C*(1-p.a)*3.5;
    if(r>0){const gr=CTX.createRadialGradient(p.x*C+C/2,p.y*C+C/2,0,p.x*C+C/2,p.y*C+C/2,r);
      gr.addColorStop(0,`rgba(0,232,154,${p.a*0.45})`);gr.addColorStop(1,'transparent');
      CTX.fillStyle=gr;CTX.beginPath();CTX.arc(p.x*C+C/2,p.y*C+C/2,r,0,Math.PI*2);CTX.fill();}
    p.a-=0.055;
  }
  sn.pulses=sn.pulses.filter(p=>p.a>0);

  const fp=sn.food,pulse=0.65+0.35*Math.sin(sn.tick*0.14);
  glow('#ff0a6c',13*pulse);CTX.font=`${C*1.1|0}px serif`;
  CTX.textAlign='left';CTX.textBaseline='top';CTX.fillText('🍎',fp.x*C,fp.y*C);ng();

  const len=sn.body.length;
  for(let i=len-1;i>=0;i--){
    const b=sn.body[i],bx=b.x*C,by=b.y*C,t=i/len;
    if(i===0){
      glow('#00e89a',18);CTX.fillStyle='#00e89a';rr(bx+1,by+1,C-2,C-2,4);CTX.fill();ng();
      const dx=sn.dir.x,dy=sn.dir.y;
      let e1x,e1y,e2x,e2y;
      if(dx===1){e1x=bx+C-8;e1y=by+4;e2x=bx+C-8;e2y=by+C-8;}
      else if(dx===-1){e1x=bx+3;e1y=by+4;e2x=bx+3;e2y=by+C-8;}
      else if(dy===-1){e1x=bx+4;e1y=by+3;e2x=bx+C-9;e2y=by+3;}
      else{e1x=bx+4;e1y=by+C-8;e2x=bx+C-9;e2y=by+C-8;}
      CTX.fillStyle='#fff';CTX.fillRect(e1x,e1y,5,5);CTX.fillRect(e2x,e2y,5,5);
      CTX.fillStyle='#111';CTX.fillRect(e1x+1,e1y+1,3,3);CTX.fillRect(e2x+1,e2y+1,3,3);
    }else{
      const a=0.95-t*0.52,g2=Math.floor(232*(1-t*0.28));
      CTX.shadowColor=i===1?'rgba(0,232,154,0.35)':'transparent';CTX.shadowBlur=i===1?7:0;
      CTX.fillStyle=`rgba(0,${g2},154,${a})`;rr(bx+2,by+2,C-4,C-4,3);CTX.fill();
      if(i%3===0&&a>0.4){CTX.fillStyle=`rgba(255,255,255,${a*0.1})`;CTX.fillRect(bx+5,by+5,C-10,C-10);}
      CTX.shadowBlur=0;
    }
  }
  glow('#00e89a',5);CTX.strokeStyle='rgba(0,232,154,0.2)';CTX.lineWidth=2;CTX.strokeRect(1,1,LW-2,LH-2);ng();
}

/* ══════════════════════════════════════════════
   ⑤ SPRING QUEST  –  POGO the bouncy explorer
   Mechanic: auto-bounce on platforms, move L/R
   Platform types: normal / moving / crumble / spring
   Enemies: blobs that float down; shoot by tapping up
   Score = height reached (scroll distance)
══════════════════════════════════════════════ */
const DL_WORLDS=[
 {id:1,name:"MEADOW SKIES", color:"#00e89a",sky0:"#071a10",sky1:"#0d2e1a",platCol:"#1a5c2a",platTop:"#22cc44",groundCol:"#0a1e10",ambient:"leaves"},
 {id:2,name:"JUNGLE CANOPY",color:"#ffc107",sky0:"#0a0e02",sky1:"#131a04",platCol:"#2a3c00",platTop:"#88cc00",groundCol:"#0e1400",ambient:"fire"},
 {id:3,name:"COSMIC VOID",  color:"#a855f7",sky0:"#02000a",sky1:"#06001a",platCol:"#1a0040",platTop:"#a855f7",groundCol:"#04000e",ambient:"stars"},
];
let dj={};
function resetDoodle(){
  const world=DL_WORLDS.find(w=>w.id===cLevel)||DL_WORLDS[0];
  const PLAT_W=80,PLAT_H=12;
  const plats=[];
  // generate starting platforms
  for(let i=0;i<12;i++){
    plats.push({x:rnd(10,LW-PLAT_W-10),y:LH-80-i*80,w:PLAT_W,h:PLAT_H,type:'normal',vx:0,alive:true,bounced:false});
  }
  plats[0]={x:LW/2-PLAT_W/2,y:LH-80,w:PLAT_W,h:PLAT_H,type:'normal',vx:0,alive:true,bounced:false};
  dj={
    x:LW/2,y:LH-120,vx:0,vy:0,
    plats,enemies:[],bullets:[],
    scroll:0,maxScroll:0,
    tick:0,world,
    shootCool:0,
    facingR:true,
    squash:1,squashV:0,
    highestY:LH-120,
  };
  // initial bounce
  dj.vy=-18;
}
function djShift(d){if(phase==="playing")dj.vx=d*4.5;}
function djShoot(){
  if(dj.shootCool>0||phase!=="playing")return;
  SFX.score();dj.shootCool=18;
  dj.bullets.push({x:dj.x,y:dj.y-20,vy:-9,alive:true});
}
function doodleMove(d){djShift(d);}
function doodleShoot(){djShoot();}
function tickDoodle(){
  const GRAV=0.45,PLAT_W=80,PLAT_H=12;
  dj.tick++;
  const world=dj.world;
  if(dj.shootCool>0)dj.shootCool--;

  // ── BACKGROUND ──
  const bg=CTX.createLinearGradient(0,0,0,LH);
  bg.addColorStop(0,world.sky0);bg.addColorStop(1,world.sky1);
  CTX.fillStyle=bg;CTX.fillRect(0,0,LW,LH);
  // world-specific bg details
  if(world.id===3){// stars for cosmic
    for(let i=0;i<60;i++){const sx=(i*137+dj.scroll*0.02|0)%LW,sy=(i*91+dj.scroll*0.03|0)%LH;CTX.fillStyle=`rgba(255,255,255,${0.2+0.5*((i*17)%7/7)})`;CTX.fillRect(sx,sy,1.5,1.5);}
  } else if(world.id===2){// jungle canopy blobs
    CTX.fillStyle='rgba(0,50,0,0.35)';
    for(let i=0;i<7;i++){const bx=(i*62+(dj.tick*0.05|0))%LW;CTX.beginPath();CTX.arc(bx,18+Math.sin(i*1.4)*10,28+i*6,0,Math.PI*2);CTX.fill();}
  } else {// meadow: gradient hills
    CTX.fillStyle='rgba(0,80,20,0.2)';
    for(let i=0;i<4;i++){const hx=(i*110+20)%LW,hh=35+i*18;CTX.beginPath();CTX.arc(hx+hh/2,LH+10,hh+60,0,Math.PI,true);CTX.fill();}
  }

  // ambient particles
  if(dj.tick%5===0){
    if(world.ambient==='leaves')PARTS.emit(Math.random()*LW,0,{n:1,type:'leaves',s0:0.5,s1:1.2,up:-0.3});
    else if(world.ambient==='stars')PARTS.emit(rnd(0,LW),rnd(0,LH),{n:1,type:'stars',s0:0.3,s1:0.8});
    else if(world.ambient==='fire')PARTS.emit(rnd(0,LW),LH,{n:1,type:'fire',s0:0.5,s1:1.5,up:1.2});
  }

  // ── PHYSICS ──
  dj.vy+=GRAV;
  dj.x+=dj.vx;dj.y+=dj.vy;
  dj.vx*=0.86;// friction
  // wrap X
  if(dj.x<0)dj.x=LW;if(dj.x>LW)dj.x=0;

  // squash/stretch
  dj.squashV*=0.7;dj.squash+=(1-dj.squash)*0.18+dj.squashV;dj.squash=clamp(dj.squash,0.5,1.6);

  // ── SCROLL: camera follows POGO upward ──
  const camThreshold=LH*0.42;
  if(dj.y<camThreshold){
    const dy=camThreshold-dj.y;
    dj.y=camThreshold;dj.scroll+=dy;
    dj.maxScroll=Math.max(dj.maxScroll,dj.scroll);
    // shift all entities down
    for(const p of dj.plats){p.y+=dy;}
    for(const e of dj.enemies){e.y+=dy;}
    for(const b of dj.bullets){b.y+=dy;}
    setScore(Math.round(dj.maxScroll/10));
  }

  // ── PLATFORM UPDATE ──
  // spawn new platforms as old ones scroll off bottom
  const topPlat=Math.min(...dj.plats.filter(p=>p.alive).map(p=>p.y));
  while(topPlat+(dj.plats.length>50?9999:0)>-80&&dj.plats.length<18){
    const lastY=Math.min(...dj.plats.map(p=>p.y));
    const pType=Math.random()<0.55?'normal':Math.random()<0.5?'moving':Math.random()<0.6?'crumble':'spring';
    dj.plats.push({x:rnd(10,LW-PLAT_W-10),y:lastY-rnd(70,110),w:PLAT_W,h:PLAT_H,type:pType,vx:pType==='moving'?(Math.random()<0.5?1.2:-1.2):0,alive:true,bounced:false});
  }
  // remove platforms that fell off bottom
  dj.plats=dj.plats.filter(p=>p.y<LH+40);
  // move moving platforms
  for(const p of dj.plats){
    if(p.type==='moving'){p.x+=p.vx;if(p.x<5||p.x>LW-p.w-5)p.vx*=-1;}
  }

  // ── PLATFORM COLLISION (only when falling) ──
  if(dj.vy>0){
    for(const p of dj.plats){
      if(!p.alive)continue;
      const foot=dj.y+16,prevFoot=foot-dj.vy;
      const inX=dj.x+12>p.x&&dj.x-12<p.x+p.w;
      const inY=prevFoot<=p.y+4&&foot>=p.y;
      if(inX&&inY){
        dj.y=p.y-16;
        if(p.type==='spring'){dj.vy=-28;dj.squashV=0.6;SFX.jump();PARTS.emit(dj.x,dj.y+16,{n:10,type:'sparks',colors:['#ffff00','#fff'],s0:3,s1:8});}
        else{dj.vy=-16;dj.squashV=0.35;SFX.land();PARTS.emit(dj.x,dj.y+16,{n:4,type:'dust',s0:1,s1:3});}
        if(p.type==='crumble'){p.bounced=true;setTimeout(()=>{p.alive=false;},200);}
        haptic(8);
        break;
      }
    }
  }

  // ── ENEMIES (blobs that drift down) ──
  if(dj.tick%90===0&&dj.enemies.length<6){
    dj.enemies.push({x:rnd(20,LW-20),y:-20,vy:0.7+Math.random()*0.6,alive:true,phase:Math.random()*Math.PI*2});
  }
  for(const e of dj.enemies){e.y+=e.vy;e.x+=Math.sin(dj.tick*0.04+e.phase)*0.6;}
  // bullet-enemy collision
  for(const b of dj.bullets){
    for(const e of dj.enemies){
      if(!b.alive||!e.alive)continue;
      if(Math.abs(b.x-e.x)<18&&Math.abs(b.y-e.y)<18){
        b.alive=false;e.alive=false;SFX.eat();
        PARTS.emit(e.x,e.y,{n:14,type:'sparks',s0:2,s1:8,colors:[world.color,'#fff']});
        setScore(score+3);
      }
    }
  }
  // player-enemy collision
  for(const e of dj.enemies){
    if(!e.alive)continue;
    if(Math.abs(dj.x-e.x)<22&&Math.abs(dj.y-e.y)<22){gameOver();return;}
  }
  dj.enemies=dj.enemies.filter(e=>e.alive&&e.y<LH+40);
  // update bullets
  for(const b of dj.bullets){b.y+=b.vy;}
  dj.bullets=dj.bullets.filter(b=>b.alive&&b.y>-20);

  // ── GAME OVER: fell off bottom ──
  if(dj.y>LH+60){gameOver();return;}

  // ── DRAW PLATFORMS ──
  for(const p of dj.plats){
    if(!p.alive||p.y>LH+10)continue;
    // top surface color
    const pcol=p.type==='crumble'?'#8B5E3C':p.type==='spring'?'#ffee00':world.platCol;
    const ptop=p.type==='crumble'?'#cc7733':p.type==='spring'?'#ffff88':world.platTop;
    // glow on spring
    if(p.type==='spring'){glow('#ffee00',10);}
    CTX.fillStyle=pcol;rr(p.x,p.y,p.w,p.h,4);CTX.fill();
    CTX.fillStyle=ptop;CTX.fillRect(p.x+2,p.y,p.w-4,3);
    if(p.type==='spring'){
      CTX.fillStyle='#cc8800';CTX.fillRect(p.x+p.w/2-5,p.y-7,10,8);
      ng();
    }
    ng();
  }

  // ── DRAW ENEMIES ──
  for(const e of dj.enemies){
    if(!e.alive)continue;
    glow(world.color,12);
    CTX.font='26px serif';CTX.textAlign='center';CTX.textBaseline='middle';
    CTX.fillText(world.id===3?'👾':world.id===2?'🐛':'🐸',e.x|0,e.y|0);
    ng();
  }

  // ── DRAW BULLETS ──
  for(const b of dj.bullets){
    if(!b.alive)continue;
    glow(world.color,8);
    CTX.fillStyle=world.color;
    CTX.beginPath();CTX.arc(b.x|0,b.y|0,5,0,Math.PI*2);CTX.fill();
    ng();
  }

  // ── DRAW POGO ──
  CTX.save();CTX.translate(dj.x|0,dj.y|0);
  CTX.scale(dj.facingR?1:-1,1);
  CTX.scale(2-dj.squash,dj.squash); // squash/stretch
  glow(world.color,18);
  CTX.font='36px serif';CTX.textAlign='center';CTX.textBaseline='middle';
  CTX.fillText('🐸',0,0);
  ng();CTX.restore();

  PARTS.update();PARTS.draw();

  // ── HUD ──
  CTX.fillStyle='rgba(0,0,0,0.3)';rr(8,8,90,28,6);CTX.fill();
  CTX.fillStyle=world.color;CTX.font='bold 11px "Exo 2",sans-serif';
  CTX.textAlign='left';CTX.textBaseline='middle';
  CTX.fillText(`⬆ ${score}`,16,22);
}

</script>

<script>
/* ════════════════════════════════════════════
   OPEN / START / LEAVE GAME
════════════════════════════════════════════ */
const GAME_INFO={
 flappy:{e:"🐦",c:"#00f2ff",t:"FLOCK",        hint:"TAP · SPACE TO FLAP  ·  BIRK FLIES"},
 geo:   {e:"🟦",c:"#ff0a6c",t:"PRISM RUNNER", hint:"TAP · SPACE · DOUBLE JUMP  ·  BLOC RUNS"},
 temple:{e:"🏂",c:"#ffc107",t:"RUSH LANES",   hint:"◀ ▶ SWIPE LEFT/RIGHT  ·  ZEPHYR RIDES"},
 snake: {e:"🐍",c:"#00e89a",t:"VIPER",        hint:"ARROWS · SWIPE  ·  GROW REX"},
 doodle:{e:"🐸",c:"#a855f7",t:"SPRING QUEST", hint:"◀ ▶ TILT/SWIPE  ·  POGO BOUNCES"},
};

function openGame(gameId,levelId){
 cGame=gameId;cLevel=levelId||1;phase="idle";score=0;sessionCoins=0;
 const info=GAME_INFO[gameId];
 const lvs={geo:GEO_LV,flappy:FL_LV,temple:BIOMES};
 const lv=(lvs[gameId]||[]).find(l=>l.id===levelId);
 // header
 $("ghtitle").textContent=`${info.e} ${lv?.name||info.t}`;
 $("ghtitle").style.color=info.c;
 $("ghtitle").style.textShadow=`0 0 10px ${info.c}66`;
 $("ghsc").textContent="0";$("ghsc").style.color=info.c;
 $("ghcoin").style.display="none";$("ghcoin").textContent="";
 // overlay
 $("govl-icon").textContent=info.e;
 $("govl-title").textContent=lv?.name||info.t;
 $("govl-title").style.color=info.c;
 $("govl-title").style.textShadow=`0 0 18px ${info.c}`;
 $("govl-btn").style.borderColor=info.c;$("govl-btn").style.color=info.c;
 $("govl-btn").textContent="▶  PLAY";
 $("govl-stats").classList.add("hidden");$("govl-stats").innerHTML="";
 $("govl-hint").textContent=info.hint;
 $("govl").classList.remove("hidden");
 // dpad
 const dp=$("dpad");dp.innerHTML="";dp.style.pointerEvents="none";
 if(gameId==="snake"){
  dp.style.pointerEvents="";
  dp.innerHTML=`<div class="dpg">
   <div></div><button class="dpb" onpointerdown="snDir([0,-1])">▲</button><div></div>
   <button class="dpb" onpointerdown="snDir([-1,0])">◀</button><div></div><button class="dpb" onpointerdown="snDir([1,0])">▶</button>
   <div></div><button class="dpb" onpointerdown="snDir([0,1])">▼</button><div></div>
  </div>`;
 } else if(gameId==="temple"||gameId==="doodle"){
  dp.style.pointerEvents="";
  const lFn=gameId==="doodle"?"doodleMove(-1)":"templeShift(-1)";
  const rFn=gameId==="doodle"?"doodleMove(1)":"templeShift(1)";
  dp.innerHTML=`<button class="dplr" onpointerdown="${lFn}">◀</button><button class="dplr" onpointerdown="${rFn}">▶</button>`;
 }
 // show game screen
 document.getElementById("s-hub").style.display="";
 ["s-hub","s-games","s-shop","s-profile"].forEach(id=>$(id)?.classList.add("hidden"));
 $("nav").style.display="none";
 $("gs").classList.remove("hidden");
 resizeCvs();
}

function startGame(){
 cancelAnimationFrame(rafId);
 phase="playing";score=0;sessionCoins=0;
 setScore(0);$("ghcoin").style.display="none";$("ghcoin").textContent="";
 $("govl").classList.add("hidden");
 resizeCvs();
 if(cGame==="flappy")resetFlappy();
 if(cGame==="geo")   resetGeo();
 if(cGame==="temple")resetTemple();
 if(cGame==="snake") resetSnake();
 if(cGame==="doodle")resetDoodle();
 function loop(){
  if(phase!=="playing")return;
  CTX.clearRect(0,0,LW,LH);
  _applyShake();
  CTX.save();CTX.translate(_shakeX,_shakeY);
  if(cGame==="flappy")tickFlappy();
  if(cGame==="geo")   tickGeo();
  if(cGame==="temple")tickTemple();
  if(cGame==="snake") tickSnake();
  if(cGame==="doodle")tickDoodle();
  CTX.restore();
  rafId=requestAnimationFrame(loop);
 }
 rafId=requestAnimationFrame(loop);
}

function leaveGame(){
 cancelAnimationFrame(rafId);phase="idle";cGame="";
 $("gs").classList.add("hidden");
 $("nav").style.display="";
 // restore last nav screen
 $("s-"+curScr).classList.remove("hidden");
 updCoins();
}

/* ════════════════════════════════════════════
   INPUT
════════════════════════════════════════════ */
let ptx=0,pty=0;
document.addEventListener("keydown",e=>{
 if(!["Space","ArrowUp","ArrowDown","ArrowLeft","ArrowRight"].includes(e.code))return;
 e.preventDefault();if(phase!=="playing")return;
 if(cGame==="flappy"&&(e.code==="Space"||e.code==="ArrowUp"))flap();
 if(cGame==="geo"&&(e.code==="Space"||e.code==="ArrowUp"))geoJump();
 if(cGame==="temple"){if(e.code==="ArrowLeft")templeShift(-1);if(e.code==="ArrowRight")templeShift(1);}
 if(cGame==="doodle"){if(e.code==="ArrowLeft")doodleMove(-1);if(e.code==="ArrowRight")doodleMove(1);if(e.code==="Space"||e.code==="ArrowUp")djShoot();}
 if(cGame==="snake"){const m={ArrowUp:[0,-1],ArrowDown:[0,1],ArrowLeft:[-1,0],ArrowRight:[1,0]};if(m[e.code])snDir(m[e.code]);}
});
document.getElementById("cwrap").addEventListener("pointerdown",e=>{
 ptx=e.clientX;pty=e.clientY;if(phase!=="playing")return;
 if(cGame==="flappy")flap();if(cGame==="geo")geoJump();
});
document.getElementById("cwrap").addEventListener("pointerup",e=>{
 if(phase!=="playing")return;
 const dx=e.clientX-ptx,dy=e.clientY-pty;
 if(Math.sqrt(dx*dx+dy*dy)<12)return;
 if(cGame==="temple"){if(Math.abs(dx)>16)templeShift(dx<0?-1:1);}
 if(cGame==="doodle"){if(Math.abs(dx)>14){dj.vx=(dx<0?-1:1)*4.5;dj.facingR=dx>0;}else if(dy<-20)djShoot();}
 if(cGame==="snake"){if(Math.abs(dx)>Math.abs(dy)&&Math.abs(dx)>16)snDir(dx<0?[-1,0]:[1,0]);else if(Math.abs(dy)>16)snDir(dy<0?[0,-1]:[0,1]);}
});

/* ── INIT ── */
renderHub();
</script>

