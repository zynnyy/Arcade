}
function _fbBgSpace(tick,gs){
  // 3-layer star field
  for(let L=0;L<3;L++){
    const cnt=[60,30,15][L],spd=[0.03,0.1,0.25][L],sz=[0.5,1,1.5][L];
    CTX.fillStyle=`rgba(255,255,255,${[0.4,0.6,0.9][L]})`;
    for(let i=0;i<cnt;i++){
      const sx=((i*179+L*300)-(gs*spd))%LW;
      const sy=(i*101+L*200)%FB.GY;
      const ss=sz*(0.7+Math.sin(tick*0.05+i)*0.3);
      CTX.fillRect(sx|0,sy|0,ss,ss);
    }
  }
  // nebula blobs
  CTX.save();CTX.globalAlpha=0.07;
  [{x:80,y:100,rx:100,ry:50,c:'#a855f7'},{x:280,y:60,rx:80,ry:40,c:'#00f2ff'},{x:340,y:150,rx:70,ry:45,c:'#3b82f6'}].forEach(b=>{
    CTX.fillStyle=b.c;CTX.beginPath();CTX.ellipse(b.x,b.y,b.rx,b.ry,0,0,Math.PI*2);CTX.fill();
  });
  CTX.restore();
}
function _fbBgStars(tick,gs){
  CTX.fillStyle='rgba(180,210,255,0.5)';
  for(let i=0;i<50;i++){const sx=((i*173)-(gs*0.04))%LW,sy=(i*107)%FB.GY;CTX.fillRect(sx|0,sy|0,i%7===0?2:1,i%7===0?2:1);}
}
function _fbBgRain(tick,gs,heavy){
  CTX.save();CTX.globalAlpha=heavy?0.18:0.12;CTX.strokeStyle='#aaccff';CTX.lineWidth=0.8;
  const cnt=heavy?40:22;
  for(let i=0;i<cnt;i++){
    const rx=((i*97+tick*4)-(gs*0.1))%LW,ry=((tick*6+i*200))%FB.GY;
    CTX.beginPath();CTX.moveTo(rx,ry);CTX.lineTo(rx-2,ry+14);CTX.stroke();
  }
  CTX.restore();
}
function _fbBgClouds(tick,gs,col){
  for(let i=0;i<6;i++){
    const cx=((i*120+20)-(gs*0.12))%LW,cy=40+i*45;
    CTX.fillStyle=col||'rgba(100,110,130,0.18)';
    CTX.beginPath();CTX.ellipse(cx,cy,55+(i%3)*20,20+(i%2)*10,0,0,Math.PI*2);CTX.fill();
    CTX.beginPath();CTX.ellipse(cx+30,cy-8,35,16,0,0,Math.PI*2);CTX.fill();
  }
}
function _fbLightning(tick){
  if(tick%220<3){
    CTX.save();CTX.globalAlpha=0.55+Math.random()*0.3;CTX.fillStyle='#eeeeff';CTX.fillRect(0,0,LW,FB.GY);CTX.restore();
  }
}
function _fbDrawPipe(p,lv,GY){
  const bot=p.ty+lv.gap;
  const pc=lv.pipe,pg2=lv.pipeGlow;
  // pipe body gradient
  const gr=CTX.createLinearGradient(p.x,0,p.x+FB.PW,0);
  if(lv.pipeStyle==='neon'){
    gr.addColorStop(0,pc+'88');gr.addColorStop(0.4,pc);gr.addColorStop(1,pc+'88');
  } else if(lv.pipeStyle==='crystal'){
    gr.addColorStop(0,pc+'44');gr.addColorStop(0.5,pc+'cc');gr.addColorStop(1,pc+'44');
  } else {
    gr.addColorStop(0,pc+'aa');gr.addColorStop(0.5,pc);gr.addColorStop(1,pc+'88');
  }
  glow(pg2,lv.pipeStyle==='neon'?18:lv.pipeStyle==='crystal'?14:8);
  CTX.fillStyle=gr;
  CTX.fillRect(p.x|0,0,FB.PW,p.ty|0);
  CTX.fillRect(p.x|0,bot|0,FB.PW,GY-bot);
  // cap
  CTX.fillStyle=pg2;
  CTX.fillRect((p.x-5)|0,(p.ty-12)|0,FB.PW+10,12);
  CTX.fillRect((p.x-5)|0,bot|0,FB.PW+10,12);
  // highlight strip
  CTX.fillStyle='rgba(255,255,255,0.12)';
  CTX.fillRect((p.x+4)|0,0,7,p.ty-12);
  CTX.fillRect((p.x+4)|0,(bot+12)|0,7,GY-bot-12);
