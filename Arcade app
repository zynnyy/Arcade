      const mh=50+(i*41)%(L?60:90);
      CTX.beginPath();CTX.moveTo(mx,base);CTX.lineTo(mx+mh*0.6,base-mh);CTX.lineTo(mx+mh*1.3,base);CTX.closePath();CTX.fill();
    }
