const CVS=document.getElementById("gc2");
const CTX=CVS.getContext("2d");
const WRAP=document.getElementById("cwrap");
const LW=390,LH=700;

let cGame="",cLevel=1,phase="idle",score=0,sessionCoins=0,rafId=null;

function resizeCvs(){
 const sc=Math.min(WRAP.clientWidth/LW,WRAP.clientHeight/LH);
 CVS.width=LW;CVS.height=LH;
 CVS.style.width=(LW*sc)+"px";CVS.style.height=(LH*sc)+"px";
 CVS.style.left=((WRAP.clientWidth-LW*sc)/2)+"px";
 CVS.style.top=((WRAP.clientHeight-LH*sc)/2)+"px";
}
window.addEventListener("resize",()=>{if(cGame)resizeCvs();});

function setScore(n){
 score=n;const el=$("ghsc");el.textContent=n;
 el.classList.remove("flash");void el.offsetWidth;el.classList.add("flash");
}
function addCoin(n){
 const mult=store.equipped?.powerup==="pw_double"?2:1;
 const earned=n*mult;
 sessionCoins+=earned;store.coins+=earned;store.coinsEarned=(store.coinsEarned||0)+earned;
 $("ghcoin").style.display="";$("ghcoin").textContent=`🪙+${sessionCoins}`;
}
function gameOver(){
 phase="dead";cancelAnimationFrame(rafId);haptic(40);
 SFX.death();shake(18);
 // particle explosion at player position
 const px=cGame==="flappy"?FB.BX:cGame==="geo"?GD.PX:cGame==="doodle"?(dj?.x||LW/2):LW/2;
 const py=cGame==="flappy"?(fb?.by||LH/2):cGame==="geo"?(gd?.py||GD.FL):cGame==="doodle"?(dj?.y||LH/2):LH/2;
 PARTS.emit(px,py,{n:30,type:"sparks",s0:3,s1:10,up:2});
 PARTS.emit(px,py,{n:15,type:"fire",s0:2,s1:7});
 const bk=`${cGame}_${cLevel}`;
 const prev=store.bests?.[bk]||0;
 store.bests={...store.bests,[bk]:Math.max(prev,score),[cGame]:Math.max(store.bests?.[cGame]||0,score)};
 saveStore();
 $("govl-icon").textContent="💀";
 $("govl-title").textContent="GAME OVER";
 $("govl-stats").innerHTML=`
  <div class="gs-stat"><div class="sl">SCORE</div><div class="sv">${score}</div></div>
  <div class="gs-stat"><div class="sl">BEST</div><div class="sv">${store.bests[bk]}</div></div>
  ${sessionCoins>0?`<div class="gs-stat gold"><div class="sl">EARNED</div><div class="sv">🪙${sessionCoins}</div></div>`:""}`;
 $("govl-stats").classList.remove("hidden");
 $("govl-btn").textContent="↺  RETRY";
 $("govl").classList.remove("hidden");
}

/* ── AUDIO ENGINE ── */
class AudioEngine{
 constructor(){try{this.ac=new(window.AudioContext||window.webkitAudioContext)();}catch(_){}}
 _resume(){if(this.ac?.state==='suspended')this.ac.resume();}
 _osc(f0,f1,dur,type='sine',vol=0.15){
  if(!this.ac)return;this._resume();
  const t=this.ac.currentTime,o=this.ac.createOscillator(),g=this.ac.createGain();
  o.connect(g);g.connect(this.ac.destination);o.type=type;
  o.frequency.setValueAtTime(f0,t);o.frequency.exponentialRampToValueAtTime(f1,t+dur);
  g.gain.setValueAtTime(vol,t);g.gain.exponentialRampToValueAtTime(0.001,t+dur);
  o.start(t);o.stop(t+dur+0.05);
 }
 _noise(dur=0.25,vol=0.28){
  if(!this.ac)return;this._resume();
  const sr=this.ac.sampleRate,buf=this.ac.createBuffer(1,sr*dur,sr),d=buf.getChannelData(0);
  for(let i=0;i<d.length;i++)d[i]=(Math.random()*2-1)*(1-i/d.length);
  const src=this.ac.createBufferSource(),g=this.ac.createGain();
  src.buffer=buf;src.connect(g);g.connect(this.ac.destination);
  g.gain.setValueAtTime(vol,this.ac.currentTime);src.start();
 }
 flap(){this._osc(300,480,0.08,'triangle',0.1);}
 jump(){this._osc(420,700,0.1,'sine',0.13);}
 score(){this._osc(660,900,0.08,'sine',0.11);}
 coin(){this._osc(880,1200,0.07,'sine',0.09);}
 death(){this._noise(0.3,0.32);this._osc(260,80,0.28,'sawtooth',0.16);}
 hit(){this._osc(180,80,0.12,'square',0.2);}
 eat(){this._osc(520,760,0.06,'sine',0.1);}
 shift(){this._osc(320,440,0.05,'triangle',0.08);}
 land(){this._osc(200,160,0.06,'triangle',0.07);}
}
const SFX=new AudioEngine();

/* ── SCREEN SHAKE ── */
let _shakePow=0,_shakeX=0,_shakeY=0;
function shake(p){_shakePow=Math.max(_shakePow,p);}
function _applyShake(){
 if(_shakePow<0.1){_shakeX=_shakeY=_shakePow=0;return;}
 _shakeX=(Math.random()-.5)*_shakePow*2;
 _shakeY=(Math.random()-.5)*_shakePow*2;
 _shakePow*=0.82;
}

/* Draw utils (used by engines) */
function rr(x,y,w,h,r){CTX.beginPath();CTX.moveTo(x+r,y);CTX.lineTo(x+w-r,y);CTX.arcTo(x+w,y,x+w,y+r,r);CTX.lineTo(x+w,y+h-r);CTX.arcTo(x+w,y+h,x+w-r,y+h,r);CTX.lineTo(x+r,y+h);CTX.arcTo(x,y+h,x,y+h-r,r);CTX.lineTo(x,y+r);CTX.arcTo(x,y,x+r,y,r);CTX.closePath();}
function glow(c,b){CTX.shadowColor=c;CTX.shadowBlur=b;}
function ng(){CTX.shadowColor="transparent";CTX.shadowBlur=0;}

/* ── PARTICLES (enhanced with types) ── */
const _PTYPE={
 fire:  {colors:['#ff4400','#ff7700','#ffaa00','#ffdd00'],grav:-.1, up:2.5,d0:.03,d1:.055,sz0:3,sz1:7},
 ember: {colors:['#ff6600','#ff4400','#ffaa00'],          grav:-.05,up:1.5,d0:.02,d1:.04, sz0:2,sz1:4},
 snow:  {colors:['#aaddff','#cceeff','#ffffff'],           grav:.015,up:0,  d0:.007,d1:.016,sz0:2,sz1:4},
 leaves:{colors:['#2d8a00','#4caa00','#88cc00','#aadd44'],grav:.05, up:0,  d0:.01,d1:.025, sz0:3,sz1:6},
 electric:{colors:['#00f2ff','#ffffff','#88eeff'],         grav:0,   up:0,  d0:.04,d1:.08, sz0:2,sz1:5},
 crystal:{colors:['#ff00ff','#00f2ff','#ffffff','#aa00ff'],grav:.03, up:0,  d0:.025,d1:.05,sz0:2,sz1:5},
 sparks:{colors:['#ffc107','#ffffff','#ffee44'],           grav:.08, up:1,  d0:.04,d1:.07, sz0:2,sz1:4},
 stars: {colors:['#ffffff','#ffffcc','#ccddff'],           grav:0,   up:0,  d0:.008,d1:.02,sz0:1,sz1:3},
 smoke: {colors:['#666655','#888877','#aaa999'],           grav:-.02,up:0.8,d0:.01,d1:.022,sz0:5,sz1:10},
 dust:  {colors:['#aa9977','#bbaa88','#ccbb99'],           grav:.03, up:0,  d0:.015,d1:.03,sz0:3,sz1:7},
 blood: {colors:['#cc0000','#ff0000','#880000'],           grav:.1,  up:2,  d0:.025,d1:.05,sz0:2,sz1:5},
};
class Particles{
 constructor(){this.p=[];}
 emit(x,y,o={}){
  const cfg={...(_PTYPE[o.type]||{}), ...o};
  for(let i=0;i<(cfg.n||8);i++){
   const a=rnd(0,Math.PI*2),sp=rnd(cfg.s0||1,cfg.s1||4);
   this.p.push({x,y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-(cfg.up||0),
    life:1,decay:rnd(cfg.d0||.025,cfg.d1||.05),
    size:rnd(cfg.sz0||2,cfg.sz1||5),
    color:cfg.colors?pick(cfg.colors):(cfg.c||'#fff'),
    grav:cfg.grav!==undefined?cfg.grav:.08});
  }
 }
 update(){for(const p of this.p){p.x+=p.vx;p.y+=p.vy;p.vy+=p.grav;p.life-=p.decay;}this.p=this.p.filter(p=>p.life>0);}
 draw(){for(const p of this.p){CTX.globalAlpha=p.life*.9;CTX.fillStyle=p.color;CTX.beginPath();CTX.arc(p.x,p.y,p.size*p.life,0,Math.PI*2);CTX.fill();}CTX.globalAlpha=1;}
}
const PARTS=new Particles();
</script>

<script>
/* ══════════════════════════════════════════════
   ① FLAPPY FLOCK
   Bird faces RIGHT (flipped horizontally).
   Gravity: 0.48, Flap: -9.2, Terminal: 11
   Pipe gap: 155px constant.
   Collision: circle-AABB with 5px inset.
══════════════════════════════════════════════ */
const FB={GRAV:0.48,FLAP:-9.2,TERM:11,PW:56,GAP:155,SPD0:2.5,BR:13,BX:85,GY:LH-68};
let fb={};
function resetFlappy(){fb={by:LH/2,vy:0,pipes:[],tick:0,spd:FB.SPD0,gs:0};}
