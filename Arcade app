   <div id="glist"></div>
  </div>
  <div id="s-lvls" class="hidden">
   <div style="display:flex;align-items:center;gap:12px;margin-bottom:22px;">
    <button onclick="showGList()" style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.14);border-radius:10px;padding:9px 14px;color:#aaa;font-family:Exo 2,sans-serif;font-weight:600;font-size:10px;letter-spacing:.06em;">◄ BACK</button>
    <div id="lvl-title" style="font-family:Exo 2,sans-serif;font-weight:800;font-size:15px;letter-spacing:.13em;"></div>
   </div>
   <div id="lvllist"></div>
  </div>
 </div>
</div>

<!-- ═══ SHOP ═══ -->

<div id="s-shop" class="screen hidden">
 <div style="position:relative;z-index:1;padding:calc(var(--st) + 28px) 18px 0;">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
   <div>
    <div style="font-family:Exo 2,sans-serif;font-weight:900;font-size:22px;letter-spacing:.14em;">SHOP</div>
    <div style="font-family:Rajdhani,sans-serif;font-size:11px;color:rgba(255,255,255,.32);letter-spacing:.15em;">UNLOCK SKINS &amp; GEAR</div>
   </div>
   <div class="cb"><span style="font-size:15px;">🪙</span><span id="shop-coins">0</span></div>
  </div>
  <div style="display:flex;gap:7px;margin-bottom:18px;">
   <button class="stab on" onclick="showTab('skin',this)">SKINS</button>
   <button class="stab" onclick="showTab('trail',this)">TRAILS</button>
   <button class="stab" onclick="showTab('powerup',this)">POWERUPS</button>
   <button class="stab" onclick="showTab('coins',this)">COINS</button>
  </div>
  <div id="shopitems"></div>
 </div>
</div>

<!-- ═══ PROFILE ═══ -->

<div id="s-profile" class="screen hidden">
 <div style="position:relative;z-index:1;padding:calc(var(--st) + 28px) 18px 0;">
  <div style="font-family:Exo 2,sans-serif;font-weight:900;font-size:22px;letter-spacing:.14em;margin-bottom:22px;">PROFILE</div>
  <div style="background:linear-gradient(135deg,rgba(155,93,229,.14),rgba(0,242,255,.07));border:1px solid rgba(155,93,229,.28);border-radius:18px;padding:22px 18px;margin-bottom:18px;display:flex;gap:18px;align-items:center;">
   <div style="width:64px;height:64px;border-radius:18px;background:linear-gradient(135deg,#9b5de5,#3b82f6);display:flex;align-items:center;justify-content:center;font-size:32px;">🎮</div>
   <div>
    <div style="font-family:Exo 2,sans-serif;font-weight:800;font-size:16px;">PLAYER 1</div>
    <div style="font-family:Rajdhani,sans-serif;font-size:12px;color:rgba(255,255,255,.38);margin-top:2px;">Arcade Vault Member</div>
    <div style="margin-top:8px;"><div class="cb"><span style="font-size:15px;">🪙</span><span id="prof-coins">0</span></div></div>
   </div>
  </div>
  <div class="sg" id="sgrid"></div>
  <div style="font-family:Exo 2,sans-serif;font-weight:700;font-size:10px;letter-spacing:.2em;color:rgba(255,255,255,.32);margin-bottom:12px;">HIGH SCORES</div>
  <div id="pscores"></div>
  <div style="font-family:Exo 2,sans-serif;font-weight:700;font-size:10px;letter-spacing:.2em;color:rgba(255,255,255,.32);margin-top:18px;margin-bottom:12px;">LOADOUT</div>
  <div id="pload"></div>
 </div>
</div>

<!-- ═══ GAME SCREEN ═══ -->

<div id="gs" class="hidden">
 <div id="gh">
  <button id="ghback" onclick="leaveGame()">◄ MENU</button>
  <div id="ghtitle"></div>
  <div id="ghcoin" style="display:none;"></div>
  <div id="ghsc"></div>
 </div>
 <div id="cwrap">
  <canvas id="gc2"></canvas>
  <div id="dpad"></div>
  <div id="govl">
   <div id="govl-icon" style="font-size:60px;line-height:1;">🔷</div>
   <div id="govl-title">GEO DASH</div>
   <div id="govl-stats" class="hidden"></div>
   <button id="govl-btn" onclick="startGame()">▶  PLAY</button>
   <div id="govl-hint"></div>
  </div>
 </div>
</div>

<!-- NAV -->

<div id="nav">
 <button class="nb on" onclick="navTo('hub')" id="n-hub"><span class="ni">🏠</span><span class="nl">HUB</span><div class="nbdot"></div></button>
 <button class="nb" onclick="navTo('games')" id="n-games"><span class="ni">🎮</span><span class="nl">GAMES</span><div class="nbdot"></div></button>
