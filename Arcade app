function _fbBgMountains(tick,gs,col1,col2){
  for(let L=0;L<2;L++){
    CTX.fillStyle=L?col2:col1;
    const spd=L?0.22:0.1,cnt=L?7:5,base=FB.GY*(L?0.74:0.65);
    for(let i=0;i<cnt+2;i++){
