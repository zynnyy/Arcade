}
function _fbBgCity(tick,gs,dark){
  const layers=[{cnt:14,spd:0.08,h:70,w:[25,45],y:0.72,c:dark?'#0a0400':'#0d0500'},
                {cnt:9, spd:0.18,h:110,w:[35,65],y:0.68,c:dark?'#080300':'#0b0400'},
                {cnt:6, spd:0.32,h:150,w:[50,80],y:0.60,c:dark?'#050200':'#080200'}];
