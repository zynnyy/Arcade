 if((store.owned||[]).includes(id)){toast("Already owned!",false);return;}
 if((store.coins||0)<item.price){toast("Not enough coins! 🪙",false);return;}
 store.coins-=item.price;store.owned=[...store.owned,id];saveStore();updCoins();
 toast(`✓ Unlocked ${item.name}!`);
